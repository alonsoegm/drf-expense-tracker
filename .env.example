# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================================

# Environment: development, staging, production
DJANGO_ENV=development

# Security
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-this-in-production

# Debug (NEVER set to True in production!)
DEBUG=True

# Allowed Hosts (comma-separated)
# Example: localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For local development (SQLite)
# DATABASE_URL=sqlite:///db.sqlite3

# For PostgreSQL/Azure SQL
# DATABASE_URL=postgresql://user:password@host:port/dbname
# Example: postgresql://adminuser:Pass@123@myserver.postgres.database.azure.com:5432/expenses_db?sslmode=require

DATABASE_URL=sqlite:///db.sqlite3

# CORS Configuration
# Allowed origins (comma-separated)
# Example: http://localhost:3000,https://yourfrontend.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Azure Key Vault (Stage 10 - leave empty for now)
AZURE_KEY_VAULT_URL=

# Email Configuration (future use)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Logging Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# NOTES:
# - In production, use environment variables from your hosting platform
# - Never use DEBUG=True in production
# - Always use strong SECRET_KEY in production
# - Configure proper ALLOWED_HOSTS for your domain
# ============================================================================
